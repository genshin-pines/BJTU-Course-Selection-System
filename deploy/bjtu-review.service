[Unit]
Description=BJTU Course Review Spring Boot backend
After=network.target mysql.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/bjtu-review/backend
EnvironmentFile=/etc/bjtu-review/bjtu-review.env
ExecStart=/usr/bin/java -jar /var/www/bjtu-review/backend/target/review-system-1.0.0.jar --server.port=8889
Restart=always
RestartSec=5
SuccessExitStatus=143

[Install]
WantedBy=multi-user.target
